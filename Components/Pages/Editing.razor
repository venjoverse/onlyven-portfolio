@page "/Editing"

<section class="skills-description">
    <h2 class="skills-description">Softwares Used</h2>
    <div class="skills enhanced-skills">

        <div class="skill-block">
            <img src="icons/aftereffects.png" alt="After Effects" class="skill-icon" />
            <h3 class="skill-title">After Effects</h3>
            <p class="skill-text">For motion graphics, visual effects, and dynamic video compositions.</p>
            <div class="bar"><div class="progress" style="width:78%">78%</div></div>
        </div>

        <div class="skill-block">
            <img src="icons/alightmotion.png" alt="Alight Motion" class="skill-icon" />
            <h3 class="skill-title">Alight Motion</h3>
            <p class="skill-text">My go-to for quick edits, smooth transitions, and social media-ready videos.</p>
            <div class="bar"><div class="progress" style="width:55%">55%</div></div>
        </div>

        <div class="skill-block">
            <img src="icons/canva.png" alt="Canva" class="skill-icon" />
            <h3 class="skill-title">Canva</h3>
            <p class="skill-text">Ideal for creating polished visual designs, layouts, and brand materials efficiently.</p>
            <div class="bar"><div class="progress" style="width:45%">45%</div></div>
        </div>

    </div>
</section>